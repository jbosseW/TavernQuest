    {id = "minnow", name = "Minnow", value = 5, rarity = 0.40, minDepth = 0, maxDepth = 30, locations = {"pond", "river"}, minWeight = 0.1, maxWeight = 0.3, color = {0.7, 0.7, 0.8}},
    {id = "carp", name = "Carp", value = 15, rarity = 0.25, minDepth = 20, maxDepth = 60, locations = {"pond", "river"}, minWeight = 1, maxWeight = 5, color = {0.6, 0.5, 0.3}},
    {id = "bass", name = "Bass", value = 25, rarity = 0.15, minDepth = 30, maxDepth = 80, locations = {"pond", "river", "lake"}, minWeight = 2, maxWeight = 8, color = {0.3, 0.5, 0.3}},
    {id = "trout", name = "Trout", value = 35, rarity = 0.10, minDepth = 40, maxDepth = 90, locations = {"river", "lake"}, minWeight = 1, maxWeight = 6, color = {0.8, 0.6, 0.5}},
    {id = "salmon", name = "Salmon", value = 50, rarity = 0.06, minDepth = 50, maxDepth = 100, locations = {"river", "ocean"}, minWeight = 3, maxWeight = 15, color = {0.9, 0.5, 0.4}},


-- Fishing Game Mode - Catch fish and sell them!
-- A relaxing fishing minigame with different fish types, locations, shop, and collection

local Fishing = {}
local UIAssets = require("uiassets")
local Progression = require("progression")
local Backpack = require("backpack")
local Tutorials = require("tutorials")

-- Font cache for performance
local fontCache = {}
local function getFont(size)
    if not fontCache[size] then
        fontCache[size] = love.graphics.newFont(size)
    end
    return fontCache[size]
end

-- Game state
local state = {
    active = false,
    casting = false,
    reeling = false,
    fishOnLine = nil,
    castPower = 0,
    lineDepth = 0,
    tension = 0,
    fishCaught = {},        -- {fishId = {count, bestWeight}}
    totalFishCaught = 0,
    currentLocation = "pond",
    currentRod = "basic",
    currentBait = "worm",
    baitCount = 10,
    unlockedLocations = {pond = true},
    ownedRods = {basic = true},

    -- UI state
    showShop = false,
    showCollection = false,
    showEmployees = false,
    shopTab = "rods",       -- rods, bait, locations, upgrades
    notification = nil,
    notificationTimer = 0,
    lastCatch = nil,
    lastCatchTimer = 0,

    -- Visual state
    bobberY = 0,
    bobberBob = 0,
    lineWiggle = 0,
    splashParticles = {},
    waterRipples = {},

    -- Fish on line indicator
    fishBiteTimer = 0,
    fishBiteFlash = false,
    reelingIndicator = 0,

    -- Input state for continuous reeling
    spaceHeld = false,

    -- Employees and upgrades
    employees = {},
    upgrades = {},
}

-- Fish types with rarity, value, and depth requirements

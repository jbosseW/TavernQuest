    {id = "golden_carp", name = "Golden Carp", value = 500, rarity = 0.005, minDepth = 50, maxDepth = 100, locations = {"pond", "lake"}, minWeight = 2, maxWeight = 10, color = {1, 0.85, 0.3}},
    {id = "sea_dragon", name = "Sea Dragon", value = 1000, rarity = 0.001, minDepth = 90, maxDepth = 100, locations = {"ocean"}, minWeight = 100, maxWeight = 500, color = {0.3, 0.8, 0.9}},

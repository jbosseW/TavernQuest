    {id = "tuna", name = "Tuna", value = 120, rarity = 0.05, minDepth = 60, maxDepth = 100, locations = {"ocean"}, minWeight = 20, maxWeight = 100, color = {0.3, 0.3, 0.5}},
    {id = "swordfish", name = "Swordfish", value = 200, rarity = 0.02, minDepth = 80, maxDepth = 100, locations = {"ocean"}, minWeight = 50, maxWeight = 200, color = {0.4, 0.4, 0.5}},


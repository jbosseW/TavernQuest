local function getSpecializationOptions(classId)
    return SPECIALIZATIONS[classId] or {}
end

local function getPlayerSpecialization()
    if state.player and state.player.specialization then
        local specs = SPECIALIZATIONS[state.player.class.id]
        if specs then
            for _, spec in ipairs(specs) do
                if spec.id == state.player.specialization then return spec end
            end
        end
    end
    return nil
end


        desc = "Shop discount %, companion morale",
        color = {0.9, 0.3, 0.9},
    },
}

-- Base stats for each class (27-point buy style allocation)
local CLASS_BASE_STATS = {
    warrior = {STR = 16, DEX = 12, CON = 14, INT = 8, WIS = 10, CHA = 10},
    mage    = {STR = 8, DEX = 10, CON = 10, INT = 16, WIS = 14, CHA = 12},
    rogue   = {STR = 10, DEX = 16, CON = 12, INT = 12, WIS = 10, CHA = 10},
    cleric  = {STR = 12, DEX = 10, CON = 12, INT = 10, WIS = 16, CHA = 10},
}

-- Calculate D&D-style stat modifier: (stat - 10) / 2, rounded down
local function getStatModifier(statValue)
    return math.floor((statValue - 10) / 2)
end

-- Get derived combat stats from D&D stats
local function getDerivedStats(stats, level)
    level = level or 1
    local derived = {
        -- From STR
        meleeDamageBonus = getStatModifier(stats.STR) * 2,
        carryCapacity = 100 + getStatModifier(stats.STR) * 20,

        -- From DEX
        critChance = 5 + getStatModifier(stats.DEX) * 2,  -- Base 5% + 2% per mod
        dodgeChance = getStatModifier(stats.DEX) * 2,     -- 2% per mod

        -- From CON
        hpPerLevel = 2 + getStatModifier(stats.CON) * 2,  -- Extra HP per level
        poisonResist = getStatModifier(stats.CON) * 5,    -- 5% per mod

        -- From INT
        spellDamageBonus = getStatModifier(stats.INT) * 3,
        bonusMana = getStatModifier(stats.INT) * 5,

        -- From WIS
        healingBonus = getStatModifier(stats.WIS) * 2,
        manaRegen = math.max(0, getStatModifier(stats.WIS)),  -- Mana per turn in combat

        -- From CHA
        shopDiscount = getStatModifier(stats.CHA) * 3,  -- 3% per mod
        companionMorale = getStatModifier(stats.CHA) * 5,
    }
    return derived
end


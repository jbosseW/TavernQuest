-- === TALENT LOOKUP TABLE (O(1) performance optimization) ===
-- Pre-built lookup table for instant talent access instead of O(n²) loops
local TALENT_LOOKUP = {}

-- Build lookup from universal talents
for _, t in ipairs(UNIVERSAL_TALENTS) do
    TALENT_LOOKUP[t.id] = t
end

-- Build lookup from class talents (all classes)
for classId, talents in pairs(CLASS_TALENTS) do
    for _, t in ipairs(talents) do
        TALENT_LOOKUP[t.id] = t
    end
end


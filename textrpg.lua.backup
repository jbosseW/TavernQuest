-- Get dungeon tile type by id
local function getDungeonTileType(id)
    for _, t in ipairs(DUNGEON_TILE_TYPES) do
        if t.id == id then return t end
    end
    return DUNGEON_TILE_TYPES[1] -- Default to wall
end


-- Get enemies for dungeon type
local function getDungeonEnemiesForType(dungeonType)
    if dungeonType == "vampire_den" then
        return VAMPIRE_DEN_ENEMIES
    elseif dungeonType == "cave" then
        return CAVE_ENEMIES
    elseif dungeonType == "mine" then
        return MINE_ENEMIES
    elseif dungeonType == "crypt" then
        return CRYPT_ENEMIES
    elseif dungeonType == "lich_lair" then
        return LICH_LAIR_ENEMIES
    else
        return DUNGEON_ENEMIES
    end
end


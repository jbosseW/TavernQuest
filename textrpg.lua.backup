-- Get enemies available for a player level (based on CR they can handle)
local function getAvailableEnemiesForLevel(playerLevel)
    local available = {}
    local encounterData = ENCOUNTER_TABLE[math.min(20, playerLevel)] or ENCOUNTER_TABLE[20]

    for _, enemy in ipairs(ENEMIES) do
        if encounterData[enemy.cr] then
            table.insert(available, enemy)
        end
    end
    return available
end

-- Get encounter count based on player level and enemy CR
local function getEncounterCount(playerLevel, cr)
    local encounterData = ENCOUNTER_TABLE[math.min(20, playerLevel)] or ENCOUNTER_TABLE[20]
    local countRange = encounterData[cr]

    if not countRange then
        return 1  -- Default to 1 if CR not in table
    end

    return math.random(countRange[1], countRange[2])
end

-- Legacy tier lookup for backwards compatibility
local ENEMY_TIERS = {
    {minLevel = 1, maxLevel = 3, enemies = {}},
    {minLevel = 4, maxLevel = 7, enemies = {}},
    {minLevel = 8, maxLevel = 12, enemies = {}},
    {minLevel = 13, maxLevel = 99, enemies = {}},
}

-- Populate tiers from ENEMIES list
for _, enemy in ipairs(ENEMIES) do
    if enemy.cr <= 0.5 then
        table.insert(ENEMY_TIERS[1].enemies, enemy)
    elseif enemy.cr <= 2 then
        table.insert(ENEMY_TIERS[2].enemies, enemy)
    elseif enemy.cr <= 4 then
        table.insert(ENEMY_TIERS[3].enemies, enemy)
    else
        table.insert(ENEMY_TIERS[4].enemies, enemy)
    end
end


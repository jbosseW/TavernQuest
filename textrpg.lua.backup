        color = {0.9, 0.6, 0.3},
    },
    INT = {
        name = "Intelligence",
        abbrev = "INT",
        desc = "+3 spell damage per modifier, +5 mana per modifier",
        color = {0.3, 0.5, 0.9},
    },
